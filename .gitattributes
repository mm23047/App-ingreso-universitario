# Normalizar line endings al hacer checkout/commit
# Todos los archivos de texto → LF en el repo, conversión automática al checkout

# Comportamiento por defecto: normalizar a LF en el repo
* text=auto

# Archivos Java y de código fuente → siempre LF
*.java          text eol=lf
*.xml           text eol=lf
*.properties    text eol=lf
*.sql           text eol=lf
*.json          text eol=lf
*.yaml          text eol=lf
*.yml           text eol=lf
*.html          text eol=lf
*.xhtml         text eol=lf
*.css           text eol=lf
*.js            text eol=lf
*.txt           text eol=lf
*.md            text eol=lf

# Scripts de shell → siempre LF (crítico para ejecución en Linux)
*.sh            text eol=lf
mvnw            text eol=lf

# Scripts Windows → siempre CRLF
*.bat           text eol=crlf
*.cmd           text eol=crlf
mvnw.cmd        text eol=crlf

# Archivos binarios → sin conversión
*.jar           binary
*.war           binary
*.ear           binary
*.class         binary
*.png           binary
*.jpg           binary
*.jpeg          binary
*.gif           binary
*.ico           binary
*.zip           binary
*.tar           binary
*.gz            binary
*.pdf           binary
